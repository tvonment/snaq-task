# Azure AI Foundry (Microsoft Foundry, 2026 v1 API)
# Endpoint must end in /openai/v1/  -- NOT the legacy api-version URL.
AZURE_OPENAI_ENDPOINT=https://your-resource.services.ai.azure.com/openai/v1/
AZURE_OPENAI_API_KEY=replace-me
AZURE_OPENAI_DEPLOYMENT=gpt-5-mini

# USDA FoodData Central — https://fdc.nal.usda.gov/api-key-signup
USDA_API_KEY=replace-me

# Runtime
MAX_CONCURRENT_VERIFICATIONS=5
CACHE_PATH=.cache/snaq.sqlite
LOG_LEVEL=INFO
